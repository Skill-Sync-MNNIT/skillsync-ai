# ==============================================
# SkillSync AI – Environment Variables Template
# Copy this to .env and fill in real values
# ==============================================

# ── Node.js Backend ─────────────────────────
PORT=5000
NODE_ENV=development

# Internal URL of the Python AI microservice
AI_SERVICE_URL=http://localhost:8000

# ── MongoDB Atlas (Free Tier) ────────────────
# https://cloud.mongodb.com → free M0 cluster
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/skillsync

# ── JWT Auth ─────────────────────────────────
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your_refresh_secret_here
REFRESH_TOKEN_EXPIRES_IN=7d

# ── Upstash Redis (Free Tier) ────────────────
# https://upstash.com → create free Redis DB
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ── Cloudinary (Free Tier – Resume PDF Store) 
# https://cloudinary.com → free 25GB
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Gmail SMTP (Free – OTP Emails) ───────────
# Use a dedicated Gmail: enable 2FA → App Password
GMAIL_USER=your_gmail_acc
GMAIL_APP_PASSWORD=your_16_char_app_password

# ==============================================
# ── Python AI Service ─────────────────────────
# ==============================================

# ── Google Gemini (Free Tier) ────────────────
# https://aistudio.google.com → Get API Key (no credit card)
# Used for: LLM explanations, moderation, embeddings
GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=your_groq_api_key

# ── Pinecone (Free Tier – Vector DB) ─────────
# https://pinecone.io → free 100k vectors (enough for MNNIT)
PINECONE_API_KEY=your_pinecone_key
PINECONE_INDEX=mnnit-student-embeddings
PINECONE_ENVIRONMENT=gcp-starter

# ── Python Service Settings ───────────────────
PYTHON_HOST=0.0.0.0
PYTHON_PORT=8000
TOP_K_RESULTS=10
EMBEDDING_MODEL=models/text-embedding-004
LLM_MODEL=gemini-1.5-flash

INTERNAL_SECRET=change_this_to_a_random_secret
